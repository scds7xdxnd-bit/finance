{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinanceQAGoldenCase",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "description",
    "period",
    "scenario_coverage",
    "thresholds",
    "users",
    "categories",
    "accounts",
    "opening_balances",
    "journal_entries",
    "write_mode_matrix",
    "csv_import_batches",
    "sensitive_flow_probes",
    "expected"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "qa-golden-v1"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "period": {
      "$ref": "#/$defs/period"
    },
    "scenario_coverage": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "transfer",
          "refund",
          "fee",
          "split",
          "receivable_repayment",
          "csv_overlap_exports"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "transfer"
          }
        },
        {
          "contains": {
            "const": "refund"
          }
        },
        {
          "contains": {
            "const": "fee"
          }
        },
        {
          "contains": {
            "const": "split"
          }
        },
        {
          "contains": {
            "const": "receivable_repayment"
          }
        },
        {
          "contains": {
            "const": "csv_overlap_exports"
          }
        }
      ]
    },
    "thresholds": {
      "type": "object",
      "required": [
        "coverage_count_min",
        "coverage_amount_min",
        "unlinked_recent_max",
        "pytest_coverage_min"
      ],
      "properties": {
        "coverage_count_min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "coverage_amount_min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "unlinked_recent_max": {
          "type": "integer",
          "minimum": 0
        },
        "pytest_coverage_min": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "users": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/user"
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "accounts": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/account"
      }
    },
    "opening_balances": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/opening_balance"
      }
    },
    "journal_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/journal_entry"
      }
    },
    "write_mode_matrix": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/write_mode_case"
      }
    },
    "csv_import_batches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/csv_import_batch"
      }
    },
    "sensitive_flow_probes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sensitive_flow_probe"
      }
    },
    "expected": {
      "$ref": "#/$defs/expected"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "period": {
      "type": "object",
      "required": [
        "ym",
        "start",
        "end"
      ],
      "properties": {
        "ym": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "start": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "end": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      },
      "additionalProperties": false
    },
    "user": {
      "type": "object",
      "required": [
        "key",
        "username"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "username": {
          "type": "string",
          "minLength": 1
        },
        "is_admin": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "category": {
      "type": "object",
      "required": [
        "key",
        "user",
        "name",
        "tb_group"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "user": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "tb_group": {
          "type": "string",
          "enum": [
            "asset",
            "liability",
            "equity",
            "income",
            "expense"
          ]
        }
      },
      "additionalProperties": false
    },
    "account": {
      "type": "object",
      "required": [
        "key",
        "user",
        "name",
        "category",
        "currency"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "user": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3,10}$"
        },
        "active": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "opening_balance": {
      "type": "object",
      "required": [
        "user",
        "account",
        "amount",
        "as_of_date"
      ],
      "properties": {
        "user": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "account": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "amount": {
          "type": "number"
        },
        "as_of_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      },
      "additionalProperties": false
    },
    "journal_line": {
      "type": "object",
      "required": [
        "account",
        "dc",
        "amount"
      ],
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "dc": {
          "type": "string",
          "enum": [
            "D",
            "C"
          ]
        },
        "amount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "memo": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "journal_entry": {
      "type": "object",
      "required": [
        "key",
        "user",
        "date",
        "description",
        "scenario_tags",
        "lines"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "user": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "reference": {
          "type": "string"
        },
        "scenario_tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "transfer",
              "refund",
              "fee",
              "split",
              "receivable_repayment"
            ]
          }
        },
        "lines": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/journal_line"
          }
        }
      },
      "additionalProperties": false
    },
    "write_mode_case_line": {
      "type": "object",
      "required": [
        "dc",
        "account",
        "amount"
      ],
      "properties": {
        "dc": {
          "type": "string",
          "enum": [
            "D",
            "C"
          ]
        },
        "account": {
          "type": "string",
          "minLength": 1
        },
        "amount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "memo": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "write_mode_case": {
      "type": "object",
      "required": [
        "name",
        "mode",
        "payload",
        "expected"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "journal",
            "dual",
            "legacy"
          ]
        },
        "payload": {
          "type": "object",
          "required": [
            "date",
            "description",
            "lines"
          ],
          "properties": {
            "date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "lines": {
              "type": "array",
              "minItems": 2,
              "items": {
                "$ref": "#/$defs/write_mode_case_line"
              }
            }
          },
          "additionalProperties": false
        },
        "expected": {
          "type": "object",
          "required": [
            "status_code",
            "delta_journal_entries",
            "delta_transactions",
            "delta_links"
          ],
          "properties": {
            "status_code": {
              "type": "integer",
              "minimum": 100,
              "maximum": 599
            },
            "delta_journal_entries": {
              "type": "integer"
            },
            "delta_transactions": {
              "type": "integer"
            },
            "delta_links": {
              "type": "integer"
            },
            "link_source": {
              "type": "string"
            },
            "error_contains": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "csv_import_batch": {
      "type": "object",
      "required": [
        "name",
        "user",
        "filename",
        "fixture_path",
        "write_mode",
        "idempotency_enabled",
        "force",
        "scenario_tags",
        "expected_summary"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "user": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "fixture_path": {
          "type": "string",
          "pattern": "^tests/fixtures/csv_import/.+\\.csv$"
        },
        "write_mode": {
          "type": "string",
          "enum": [
            "journal",
            "dual",
            "legacy"
          ]
        },
        "idempotency_enabled": {
          "type": "boolean"
        },
        "force": {
          "type": "boolean"
        },
        "scenario_tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "reupload",
              "overlap_export",
              "partial_duplicate"
            ]
          }
        },
        "expected_summary": {
          "type": "object",
          "required": [
            "skipped_duplicate_batch",
            "rows_new",
            "rows_duplicate",
            "rows_error",
            "count_journal",
            "count_simple",
            "duplicate_reasons",
            "error_reasons"
          ],
          "properties": {
            "skipped_duplicate_batch": {
              "type": "boolean"
            },
            "rows_new": {
              "type": "integer",
              "minimum": 0
            },
            "rows_duplicate": {
              "type": "integer",
              "minimum": 0
            },
            "rows_error": {
              "type": "integer",
              "minimum": 0
            },
            "count_journal": {
              "type": "integer",
              "minimum": 0
            },
            "count_simple": {
              "type": "integer",
              "minimum": 0
            },
            "duplicate_reasons": {
              "type": "object",
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              }
            },
            "error_reasons": {
              "type": "object",
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "sensitive_flow_probe": {
      "type": "object",
      "required": [
        "name",
        "actor_user",
        "target_user",
        "method",
        "endpoint",
        "expected_status"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "actor_user": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "target_user": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST"
          ]
        },
        "endpoint": {
          "type": "string",
          "minLength": 1
        },
        "expected_status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "must_not_include_account_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          }
        },
        "must_not_include_journal_entry_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          }
        }
      },
      "additionalProperties": false
    },
    "expected": {
      "type": "object",
      "required": [
        "reconcile_checks",
        "coverage_gates",
        "dedupe_gates",
        "scope_gates",
        "reports"
      ],
      "properties": {
        "reconcile_checks": {
          "type": "object",
          "required": [
            "unmapped_transactions",
            "mismatched_links",
            "unbalanced_journal_entries"
          ],
          "properties": {
            "unmapped_transactions": {
              "type": "integer",
              "minimum": 0
            },
            "mismatched_links": {
              "type": "integer",
              "minimum": 0
            },
            "unbalanced_journal_entries": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "coverage_gates": {
          "type": "object",
          "required": [
            "coverage_count_min",
            "coverage_amount_min",
            "unlinked_recent_max"
          ],
          "properties": {
            "coverage_count_min": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "coverage_amount_min": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "unlinked_recent_max": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "dedupe_gates": {
          "type": "object",
          "required": [
            "duplicate_batch_hits_min",
            "overlap_duplicate_rows_min",
            "partial_duplicate_group_errors_min"
          ],
          "properties": {
            "duplicate_batch_hits_min": {
              "type": "integer",
              "minimum": 0
            },
            "overlap_duplicate_rows_min": {
              "type": "integer",
              "minimum": 0
            },
            "partial_duplicate_group_errors_min": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "scope_gates": {
          "type": "object",
          "required": [
            "cross_user_leakage_count"
          ],
          "properties": {
            "cross_user_leakage_count": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "reports": {
          "type": "object",
          "required": [
            "tb_monthly",
            "statements",
            "parity"
          ],
          "properties": {
            "tb_monthly": {
              "type": "object",
              "required": [
                "asset_bd",
                "asset_balance",
                "asset_period_debit",
                "asset_period_credit",
                "liability_balance",
                "income_balance",
                "expense_balance",
                "grand_period_debit",
                "grand_period_credit"
              ],
              "properties": {
                "asset_bd": {
                  "type": "number"
                },
                "asset_balance": {
                  "type": "number"
                },
                "asset_period_debit": {
                  "type": "number"
                },
                "asset_period_credit": {
                  "type": "number"
                },
                "liability_balance": {
                  "type": "number"
                },
                "income_balance": {
                  "type": "number"
                },
                "expense_balance": {
                  "type": "number"
                },
                "grand_period_debit": {
                  "type": "number"
                },
                "grand_period_credit": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            },
            "statements": {
              "type": "object",
              "required": [
                "income",
                "balance",
                "cashflow"
              ],
              "properties": {
                "income": {
                  "type": "object",
                  "required": [
                    "revenue",
                    "expense",
                    "net_income"
                  ],
                  "properties": {
                    "revenue": {
                      "type": "number"
                    },
                    "expense": {
                      "type": "number"
                    },
                    "net_income": {
                      "type": "number"
                    }
                  },
                  "additionalProperties": false
                },
                "balance": {
                  "type": "object",
                  "required": [
                    "assets",
                    "liabilities",
                    "equity",
                    "le_sum"
                  ],
                  "properties": {
                    "assets": {
                      "type": "number"
                    },
                    "liabilities": {
                      "type": "number"
                    },
                    "equity": {
                      "type": "number"
                    },
                    "le_sum": {
                      "type": "number"
                    }
                  },
                  "additionalProperties": false
                },
                "cashflow": {
                  "type": "object",
                  "required": [
                    "opening",
                    "closing",
                    "change"
                  ],
                  "properties": {
                    "opening": {
                      "type": "number"
                    },
                    "closing": {
                      "type": "number"
                    },
                    "change": {
                      "type": "number"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "parity": {
              "type": "object",
              "required": [
                "tb_vs_statement",
                "statement_vs_pdf",
                "tb_vs_pdf"
              ],
              "properties": {
                "tb_vs_statement": {
                  "type": "boolean"
                },
                "statement_vs_pdf": {
                  "type": "boolean"
                },
                "tb_vs_pdf": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
