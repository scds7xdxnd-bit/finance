# App runtime
APP_ENV=development
SECRET_KEY=replace-with-a-strong-random-secret
FINANCE_DATABASE_URL=sqlite:///instance/finance_app.db
ALEMBIC_DATABASE_URL=sqlite:///instance/finance_app.db

# Upload/session/static
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_TTL_SECONDS=86400
MAX_CONTENT_LENGTH=10485760
UPLOAD_ALLOWED_EXTENSIONS=csv,png,jpg,jpeg,gif,pdf
UPLOAD_FOLDER=instance/uploads
STATIC_CACHE_MAX_AGE=3600

# vNext guardrails
LEDGER_WRITE_MODE=journal
SCHEMA_GUARD_ENFORCE=true
ALLOW_LEGACY_REPORT_FALLBACK=false
CSV_IDEMPOTENCY_ENABLED=true
ADMIN_ACTION_COOLDOWN_SECONDS=5

# Coverage/reconcile thresholds
LEDGER_COVERAGE_COUNT_MIN=0.99
LEDGER_COVERAGE_AMOUNT_MIN=0.995
LEDGER_UNLINKED_RECENT_MAX=0

# ML gateway (optional)
DISABLE_ML=false
MLSUGGESTER_API_URL=http://127.0.0.1:8001
MLSUGGESTER_DEFAULT_CURRENCY=KRW
MLSUGGESTER_TOPK=3
MLSUGGESTER_TIMEOUT=2.0
MLSUGGESTER_PREFER_USER_MODEL=true
MLSUGGESTER_USER_ONLY=false
MLSUGGESTER_AUTO_TRAIN_USER_MODEL=true
MLSUGGESTER_USER_MODEL_MIN_ROWS=5
